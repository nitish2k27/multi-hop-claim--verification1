# ============================================
# EXCLUDE ALL LARGE FILES (>5MB)
# ============================================

# Model directories (contains large .safetensors files ~400MB each)
models/claim_detector/final/
models/stance_detector/final/
models/ner_model/final/
models/llm_finetuned/final/

# Keep only README files in model directories
!models/*/README.md
!models/README.md

# Data directories (contains large CSV/JSON files)
data/raw/
data/processed/
data/chroma_db/

# Keep only README files in data directories  
!data/README.md
!data/*/README.md

# Test model files (125MB FastText model)
tests/models/language_detection/*.bin

# Keep README in test models
!tests/models/*/README.md

